# Application environment and secret
APP_ENV=prod
APP_SECRET=change-this-secret-in-production

# OpenSearch (optional, depending on skill usage)
OPENSEARCH_URL=http://opensearch:9200

# Langfuse Observability
LANGFUSE_ENABLED=0
LANGFUSE_BASE_URL=http://langfuse-web:3000
LANGFUSE_PUBLIC_KEY=lf_pk_local_dev
LANGFUSE_SECRET_KEY=lf_sk_local_dev
LANGFUSE_ENV=local

# LiteLLM / LLM Provider
LITELLM_BASE_URL=http://litellm:4000
LITELLM_API_KEY=dev-key
LLM_MODEL=minimax/minimax-m2.5

# Symfony settings
DEFAULT_URI=http://localhost
APP_SHARE_DIR=var/share
